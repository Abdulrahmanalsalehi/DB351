CREATE OR REPLACE TRIGGER VALIDATE_DEPARTMENT_CHAIR
BEFORE INSERT OR UPDATE ON DEPARTMENT
FOR EACH ROW
  V_COUNT NUMBER;
BEGIN
  SELECT COUNT(*)
  FROM INSTRUCTOR I
  WHERE I.IID = :NEW.CHAIR_ID
  AND DID = :NEW.DID;
  
  IF V_COUNT > 0 THEN
     RAISE_APPLICATION_ERROR(-20002, 'INSTRUCTOR' || :NEW.CHAIR_ID || 'DOES NOT BELONG TO DEPARTMENT' || :NEW.DID);
  END IF;

END;


   
