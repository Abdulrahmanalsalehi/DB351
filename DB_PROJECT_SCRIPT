CREATE OR REPLACE TRIGGER ENFORCE_INSTRUCTOR_CONFLICT
BEFORE INSERT OR UPDATE ON COURSE_SECTION
-- FOR A NEW ROW THAT IS INSERTED
FOR EACH ROW
DECLARE
   -- WILL COUNT HOW MANY ROWS HAS A CONFLICT
   V_CONFLICT_TIME NUMBER;
BEGIN
   SELECT COUNT(*)
   INTO V_CONFLICT_TIME 
   FROM COURSE_SECTION
   -- MAKE SURE THE SEMESTE, YEAR AND DAY ARE THE SAME FOR NEW VALUES ENTERED
   WHERE IID = :NEW.IID
       AND SEMESTER = :NEW.SEMESTER
       AND YEAR = :NEW.YEAR
       AND DAY = :NEW.DAY
       -- CHECK WHEN THE NEW START_TIME IS BEFORE CURRENT END_TIME & WHEN THE NEW END_TIME IS AFTER THE CURRENT START_TIME 
       -- IN OTHER WORDS, CHECK FOR INERSECTION BETWEEN NEW VALUES ENTERED AND CURRENT VALUES
       -- 'HH24:MI' IS TO CONVERT TIME INTO COMPARABLE FORM
       AND(TO_DATE(:NEW.START_TIME,'HH24:MI') < TO_DATE(END_TIME,'HH24:MI')) AND (TO_DATE(:NEW.END_TIME, 'HH24:MI') > TO_DATE(START_TIME, 'HH24:MI'));
       
    -- ROW EXISTS -> COUNT BECOMES GREATER THAN 0
    IF V_CONFLICT_TIME > 0 THEN
      RAISE_APPLICATION_ERROR(-20001, 'CONFLICT IN SCHEDULE ' || :NEW.IID || ' HAS A SECTION DURING THIS TIME');
    END IF;
END;


/


