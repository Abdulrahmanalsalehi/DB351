CREATE OR REPLACE PROCEDURE GENERATE_STUDENT_TRANSCRIPT(p_student_id IN NUMBER)
IS
   CURSOR COURSES IS
      SELECT C.CTITLE, C.CREDIT_HOURS, CS.SEMESTER, CS.YEAR, SCG.FINAL_GRADE
      FROM COURSE C
      JOIN COURSE_SECTION CS ON CS.CID = C.CID
      JOIN STUDENT_COURSE_GRADE SCG ON SCG.SCID = CS.SCID
      WHERE SCG.SID = p_student_id
      AND SCG.STATUS = 'COMPLETED';
    V_GPA NUMBER;
    
BEGIN
  DBMS_OUTPUT.PUT_LINE('COURSE_TITLE | CREDIT_HOURS | SEMESTER | YEAR | FINAL_GRADE');
  DBMS_OUTPUT.PUT_LINE('------------------------------------------------------------');

   FOR I IN COURSES 
         LOOP
           DBMS_OUTPUT.PUT_LINE(I.CTITLE || ' | ' || I.CREDIT_HOURS || ' | ' || I.SEMESTER || ' | ' || I.FINAL_GRADE);
         END LOOP;
   
   V_GPA := CALCULATE_GPA(p_student_id);
   DBMS_OUTPUT.PUT_LINE('------------------------------------------------------------');
   DBMS_OUTPUT.PUT_LINE('GPA: ' || V_GPA);

END;


