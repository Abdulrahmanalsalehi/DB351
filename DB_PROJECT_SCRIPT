-------------- DEPARTMENT --------------
CREATE TABLE DEPARTMENT(
 DID INT PRIMARY KEY,
 DNAME VARCHAR(20) NOT NULL,
 OFFICE_LOCATION VARCHAR(20),
 PHONE_NUMBER VARCHAR(20) UNIQUE,
 CHAIR_ID INT UNIQUE
);

-------------- INSTRUCTOR --------------
CREATE TABLE INSTRUCTOR(
 IID INT PRIMARY KEY,
 INAME VARCHAR(20) NOT NULL,
 EMAIL VARCHAR(20) UNIQUE NOT NULL,
 PHONE_NUMBER VARCHAR(20),
 HIRE_DATE DATE,
 DID INT NOT NULL,
 FOREIGN KEY (DID) REFERENCES DEPARTMENT(DID)
);

ALTER TABLE DEPARTMENT ADD CONSTRAINT FK_CHAIR
FOREIGN KEY(CHAIR_ID) REFERENCES INSTRUCTOR(IID);



-------------- STUDENT --------------
CREATE TABLE STUDENT(
 SID INT PRIMARY KEY,
 SNAME VARCHAR(20) NOT NULL,
 EMAIL VARCHAR(20) UNIQUE NOT NULL,
 DATE_OF_BIRTH DATE,
 GENDER VARCHAR(1) CHECK (GENDER IN ('M','F')),
 ENROLLMENT_YEAR INT,
 DID INT NOT NULL,
 ADVISOR_ID INT NOT NULL, -- EACH STUDENT HAS ONE ADVISOR
 FOREIGN KEY (DID) REFERENCES DEPARTMENT(DID),
 FOREIGN KEY (ADVISOR_ID) REFERENCES INSTRUCTOR(IID)
);


-------------- COURSE --------------
CREATE TABLE COURSE(
 CID INT PRIMARY KEY,
 CTITLE VARCHAR(30) NOT NULL,
 CREDIT_HOURS INT CHECK(CREDIT_HOURS > 0),
 DID INT NOT NULL, -- EACH COURSE BELONGS TO ONE DEPRATMENT
 FOREIGN KEY (DID) REFERENCES DEPARTMENT(DID)
);

-------------- COURSE_SECTION --------------
CREATE TABLE COURSE_SECTION(
 SCID INT PRIMARY KEY,
 SCNUMBER INT NOT NULL,
 CID INT,
 IID INT,
 RID INT,
 SEMESTER VARCHAR(30),
 YEAR INT,
 DAY VARCHAR(30),
 START_TIME VARCHAR(30),
 END_TIME VARCHAR(30),
 FOREIGN KEY (CID) REFERENCES COURSE(CID),
 FOREIGN KEY (IID) REFERENCES INSTRUCTOR(IID),
 FOREIGN KEY (RID) REFERENCES CLASSROOM(RID)
);
-------------- CLASSROOM --------------
CREATE TABLE CLASSROOM(
 RID INT PRIMARY KEY,
 RNUM VARCHAR(30) NOT NULL,
 CAPACITY INT CHECK(CAPACITY > 0),
 BUILDING_NAME VARCHAR(30)
);

-------------- EXAM --------------
CREATE TABLE EXAM(
 EID INT PRIMARY KEY,
 EXAM_TYPE VARCHAR(20) CHECK(EXAM_TYPE IN ('MIDTERM','FINAL','QUIZ')),
 SCID INT,
 EDATE DATE,
 MAX_MARKS INT CHECK (MAX_MARKS > 0),
 FOREIGN KEY (SCID) REFERENCES COURSE_SECTION(SCID) -- AN EXAM BELONGS TO A SECTION
);
-------------- EXAM_RESULT --------------
CREATE TABLE EXAM_RESULT(
 SID INT,
 SCID INT,
 EID INT,
 MARKS_OBTAINED INT CHECK (MARKS_OBTAINED >= 0),
 PRIMARY KEY (SID, EID), -- LINK STUDENT TO THE EXAM RESULT
 FOREIGN KEY (EID) REFERENCES EXAM(EID), -- AN EXAM RESULT BELONG TO AN EXAM
 FOREIGN KEY (SID) REFERENCES STUDENT(SID),
 FOREIGN KEY (SCID) REFERENCES COURSE_SECTION(SCID)
);

-------------- STUDENT_COURSE_GRADE --------------
CREATE TABLE STUDENT_COURSE_GRADE(
 SID INT,
 CID INT,
 SCID INT,
 STATUS VARCHAR(10) CHECK (STATUS IN ('COMPLETED','DROPPED')),
 FINAL_GRADE VARCHAR(2),
 FOREIGN KEY (SID) REFERENCES STUDENT(SID),
 FOREIGN KEY (CID) REFERENCES COURSE(CID),
 FOREIGN KEY (SCID) REFERENCES COURSE_SECTION(SCID)
);




