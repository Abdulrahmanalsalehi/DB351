CREATE OR REPLACE FUNCTION CALCULATE_GPA(p_student_id IN NUMBER)
RETURN NUMBER IS
-- variables needed
V_TOTAL_POINTS NUMBER := 0;
V_TOTAL_CREDITS NUMBER := 0;
V_GRADE_POINTS NUMBER;

CURSOR C_GRADES IS 
    SELECT C.CREDIT_HOURS, SCG.FINAL_GRADE
    FROM STUDENT_COURSE_GRADE SCG
    JOIN COURSE C          ON C.CID = SCG.CID -- JOIN COURSE & STUDENT_COURSE_GRADE
    WHERE SCG.SID = p_student_id -- MAKE SURE IT MATCHES THE PASSED STUDENT
    AND SCG.STATUS = 'COMPLETED';
BEGIN
   FOR RECORD IN C_GRADES 
     LOOP
        V_GRADE_POINTS := CASE RECORD.FINAL_GRADE
                      WHEN 'A'  THEN 4.0
                      WHEN 'B+' THEN 3.5
                      WHEN 'B'  THEN 3.0
                      WHEN 'C+' THEN 2.5
                      WHEN 'C'  THEN 2.0
                      WHEN 'D+' THEN 1.5
                      WHEN 'D'  THEN 1.0
                      WHEN 'F'  THEN 0.0
      END;
    V_TOTAL_POINTS := V_TOTAL_POINTS + (RECORD.CREDIT_HOURS * V_GRADE_POINTS);
    V_TOTAL_CREDITS := V_TOTAL_CREDITS + RECORD.CREDIT_HOURS;
    END LOOP;
    
    -- return 0 if no completed course
    IF V_TOTAL_CREDITS = 0 THEN
        RETURN 0;
    END IF;
    
    RETURN ROUND(V_TOTAL_POINTS / V_TOTAL_CREDITS, 2); -- ROUND FOR 2 DECIMAL PLACES
    
    EXCEPTION 
      WHEN OTHERS THEN
        RETURN 0;

END CALCULATE_GPA;
        
/
 
